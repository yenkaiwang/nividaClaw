{
  "name": "Pi BYOK",
  "tagline": "使用 Pi Coding Agent — 原生支援 Cloudflare、Anthropic、OpenAI、Gemini",
  "description": "以 Pi Coding Agent 作為小龍蝦執行引擎的範本。每隻小龍蝦可獨立選擇 provider 與 model，API key 按 provider 分開管理。Pi 原生支援多家 provider，不需要額外的轉接層。",
  "category": "ai",
  "tags": ["pi", "byok", "cloudflare", "anthropic", "openai", "gemini"],
  "version": "1.0.0",
  "support_url": "https://github.com/duotify/GitHubClawToolkit/issues",
  "homepage": "https://learn.duotify.com/courses/githubclaw",
  "byokFlow": true,
  "byokConfig": {
    "path": ".pi/settings.json",
    "providerField": "defaultProvider",
    "modelField": "defaultModel",
    "merge": true
  },
  "providers": [
    {
      "id": "cloudflare-workers-ai",
      "label": "Cloudflare Workers AI",
      "description": "使用 Cloudflare Workers AI 推論 API，免費額度內可用。",
      "isDefault": true,
      "secretName": "CLOUDFLARE_API_TOKEN",
      "defaultModel": "@cf/moonshotai/kimi-k2.6",
      "models": [
        { "value": "@cf/zai-org/glm-4.7-flash", "label": "GLM 4.7 Flash" },
        { "value": "@cf/google/gemma-4-26b-a4b-it", "label": "Gemma 4 26B" },
        { "value": "@cf/meta/llama-4-scout-17b-16e-instruct", "label": "Llama 4 Scout 17B" },
        { "value": "@cf/moonshotai/kimi-k2.5", "label": "Kimi K2.5" },
        { "value": "@cf/moonshotai/kimi-k2.6", "label": "Kimi K2.6" },
        { "value": "@cf/nvidia/nemotron-3-120b-a12b", "label": "Nemotron 3 120B" },
        { "value": "@cf/openai/gpt-oss-120b", "label": "GPT OSS 120B" },
        { "value": "@cf/openai/gpt-oss-20b", "label": "GPT OSS 20B" }
      ]
    },
    {
      "id": "anthropic",
      "label": "Anthropic",
      "description": "使用 Anthropic Claude 系列模型。",
      "secretName": "ANTHROPIC_API_KEY",
      "defaultModel": "claude-sonnet-4-6",
      "models": [
        { "value": "claude-sonnet-4-6", "label": "Claude Sonnet 4.6" },
        { "value": "claude-opus-4-7", "label": "Claude Opus 4.7" },
        { "value": "claude-opus-4-6", "label": "Claude Opus 4.6" },
        { "value": "claude-haiku-4-5", "label": "Claude Haiku 4.5" }
      ]
    },
    {
      "id": "openai",
      "label": "OpenAI",
      "description": "使用 OpenAI GPT 系列模型。",
      "secretName": "OPENAI_API_KEY",
      "defaultModel": "gpt-5-mini",
      "models": [
        { "value": "gpt-5.5", "label": "GPT-5.5" },
        { "value": "gpt-5.4", "label": "GPT-5.4" },
        { "value": "gpt-5.4-mini", "label": "GPT-5.4 Mini" },
        { "value": "gpt-5.3-codex", "label": "GPT-5.3 Codex" },
        { "value": "gpt-5-mini", "label": "GPT-5 Mini" },
        { "value": "gpt-4.1", "label": "GPT-4.1" }
      ]
    },
    {
      "id": "google",
      "label": "Google Gemini",
      "description": "使用 Google Gemini 系列模型。",
      "secretName": "GEMINI_API_KEY",
      "defaultModel": "gemini-2.5-flash",
      "models": [
        { "value": "gemini-2.0-flash", "label": "Gemini 2.0 Flash" },
        { "value": "gemini-2.5-flash", "label": "Gemini 2.5 Flash" },
        { "value": "gemini-2.5-pro", "label": "Gemini 2.5 Pro" },
        { "value": "gemini-3-flash-preview", "label": "Gemini 3 Flash (Preview)" },
        { "value": "gemini-3-pro-preview", "label": "Gemini 3 Pro (Preview)" },
        { "value": "gemini-3.1-flash-lite-preview", "label": "Gemini 3.1 Flash Lite (Preview)" },
        { "value": "gemini-3.1-pro-preview", "label": "Gemini 3.1 Pro (Preview)" }
      ]
    }
  ]
}
